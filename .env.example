SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Firebase Authentication (Project Settings -> Service Accounts -> Generate new private key,
# paste the whole downloaded JSON file as a single-line string)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...", ...}

# Vercel Blob storage (Vercel dashboard -> Storage -> Create Database -> Blob)
BLOB_READ_WRITE_TOKEN=

# M-Pesa Daraja
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=https://your-backend.up.railway.app/api/payments/mpesa/callback/
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke

# Production only (Railway sets DATABASE_URL automatically when you add Postgres)
# DATABASE_URL=postgresql://user:password@host:port/dbname
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app
